+    candidates: list[Path] = []
+    if env_dir:
+        candidates.append(Path(env_dir).expanduser())
+    candidates.extend(
+        [
+            Path.home() / ".alcatraz",
+            Path(tempfile.gettempdir()) / "alcatraz" / (os.getenv("USER") or "default"),
+        ]
+    )
+
+    seen: set[Path] = set()
+    last_error: OSError | None = None
+    for lock_root in candidates:
+        if lock_root in seen:
+            continue
+        seen.add(lock_root)
+        try:
